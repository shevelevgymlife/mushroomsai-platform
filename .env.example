# Основной бот (сайт + polling). На Render: Dashboard → Environment, имя TELEGRAM_TOKEN. Не коммитить токен.
TELEGRAM_TOKEN=
# Username бота без @ — как в @BotFather; должен совпадать с ботом из TELEGRAM_TOKEN (иначе виджет входа / ссылки неверны).
TELEGRAM_BOT_USERNAME=mushrooms_ai_bot
OPENAI_API_KEY=
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=
ADMIN_TG_ID=
# Опционально: email владельца (Google) — те же права что у ADMIN_TG_ID для создания групп
ADMIN_EMAIL=
SITE_URL=https://mushroomsai.ru
# Адрес ERC-20 SHEVELEV (Decimal Smart Chain). Альтернатива: deployment/shevelev_token_address.txt
SHEVELEV_TOKEN_ADDRESS=

# Уведомление о деплое (startup на Render) по email.
DEPLOY_NOTIFY_EMAIL_TO=
DEPLOY_NOTIFY_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# Канал оповещений о задачах/деплое
# Можно задать либо email (через SMTP), либо Telegram chat id, либо оба канала.
# Для Telegram можно использовать основной TELEGRAM_TOKEN, либо отдельный токен ниже.
DEPLOY_NOTIFY_TG_BOT_TOKEN=
DEPLOY_NOTIFY_TG_CHAT_ID=
DEPLOY_NOTIFY_TASK_CHAT_ID=
DEPLOY_NOTIFY_TASK_EMAIL_TO=
OPS_TELEGRAM_TOKEN=
TASK_AUTORUN_WEBHOOK_URL=
TASK_AUTORUN_WEBHOOK_TOKEN=
OPS_NOTIFY_DAILY_SUMMARY_HOUR_UTC=9
OPS_NOTIFY_BILLING_DUE_AT=
OPS_NOTIFY_BILLING_CURRENT_USD=0
OPS_NOTIFY_BILLING_LIMIT_USD=0
OPS_NOTIFY_BILLING_WARN_PERCENT=90

# Telegram подтверждения Да/Нет для продолжения задачи.
# Если пусто, используются значения выше.
TASK_APPROVAL_BOT_TOKEN=
TASK_APPROVAL_CHAT_ID=
TASK_APPROVAL_ALLOWED_TG_IDS=
TASK_APPROVAL_ALLOWED_TG_IDS=
