OPENAI_API_KEY=
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=
ADMIN_TG_ID=
# Владелец (полный /admin). По умолчанию в config — shevelevgymlife@gmail.com; можно переопределить.
ADMIN_EMAIL=
SITE_URL=https://mushroomsai.ru
SHEVELEV_TOKEN_ADDRESS=

# Основной бот (@neuro_fungi_bot)
TELEGRAM_TOKEN=          # токен основного бота
TELEGRAM_BOT_USERNAME=neuro_fungi_bot   # без @
TELEGRAM_BOT_TOKEN=      # токен для проверки WebApp initData (если пусто — используется TELEGRAM_TOKEN)
TELEGRAM_WEBAPP_STARTAPP=webapp
# Если Mini App открывают с другого бота (не TELEGRAM_TOKEN) — добавьте его токен(ы) через запятую, иначе initData не пройдёт проверку
TELEGRAM_WEBAPP_EXTRA_BOT_TOKENS=

# Бот уведомлений администратора (отдельный бот; имя задаёте в @BotFather)
NOTIFY_BOT_TOKEN=

# Бот обучающих постов (папки/посты для AI). Пусто — не запускается. Имя в Telegram — любое в @BotFather.
TRAINING_BOT_TOKEN=

# Бот импорта из канала: новые посты канала → та же таблица ai_training_posts (нужен отдельный токен @BotFather).
# Канал: добавить этого бота админом. CHANNEL_INGEST_ALLOWED_IDS — chat_id канала (часто -100…), несколько через запятую.
CHANNEL_INGEST_BOT_TOKEN=
CHANNEL_INGEST_ALLOWED_IDS=
CHANNEL_INGEST_FOLDER=Из канала

# Email уведомления
DEPLOY_NOTIFY_EMAIL_TO=
DEPLOY_NOTIFY_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true
DEPLOY_NOTIFY_TASK_EMAIL_TO=
TASK_AUTORUN_WEBHOOK_URL=
TASK_AUTORUN_WEBHOOK_TOKEN=
TASK_AUTORUN_SECRET=
OPS_NOTIFY_DAILY_SUMMARY_HOUR_UTC=9
OPS_NOTIFY_BILLING_DUE_AT=
OPS_NOTIFY_BILLING_CURRENT_USD=0
OPS_NOTIFY_BILLING_LIMIT_USD=0
OPS_NOTIFY_BILLING_WARN_PERCENT=90
